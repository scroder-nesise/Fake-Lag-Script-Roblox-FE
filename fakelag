-- ===== MODE CYCLING (shared logic) =====
local function cycleMode()
    currentModeIndex = currentModeIndex % #modes + 1
    lagMode = modes[currentModeIndex]
    modeValueBtn.Text = "[" .. currentModeIndex .. "/5] " .. lagMode
    TweenService:Create(modeValueBtn, TweenInfo.new(0.15), {
        BackgroundColor3 = modeColors[lagMode]
    }):Play()
    -- Sync side-effects per mode
    if lagMode == "Precise" then
        burstMode    = false
        fakeVelocity = false
    elseif lagMode == "Burst" then
        burstMode    = true
        fakeVelocity = false
    elseif lagMode == "VelocityFreeze" then
        fakeVelocity = true
        burstMode    = false
    else
        burstMode    = false
    end
    if enabled then
        setStatus("ACTIVE - " .. lagMode, C.Green)
    end
end

-- ===== TOGGLE LOGIC =====
local function toggleLag()
    enabled = not enabled
    if enabled then
        TweenService:Create(toggleBtn,  TweenInfo.new(0.2), {BackgroundColor3 = C.Green}):Play()
        TweenService:Create(accentLine, TweenInfo.new(0.3), {BackgroundColor3 = C.Green}):Play()
        TweenService:Create(mainStroke, TweenInfo.new(0.3), {Color = C.Green}):Play()
        toggleBtn.Text = "DISABLE FAKE LAG  [" .. TOGGLE_KEY.Name .. "]"
        setStatus("ACTIVE - " .. lagMode, C.Green)
        startFakeLag()
        startTimer()
    else
        TweenService:Create(toggleBtn,  TweenInfo.new(0.2), {BackgroundColor3 = C.Red}):Play()
        TweenService:Create(accentLine, TweenInfo.new(0.3), {BackgroundColor3 = C.Accent}):Play()
        TweenService:Create(mainStroke, TweenInfo.new(0.3), {Color = C.Border}):Play()
        toggleBtn.Text = "▶  ENABLE FAKE LAG  [" .. TOGGLE_KEY.Name .. "]"
        setStatus("Idle — Stopped  •  " .. TOGGLE_KEY.Name .. " toggle  |  " .. CYCLE_KEY.Name .. " cycle", C.TextSub)
        stopFakeLag()
        stopTimer()
    end
end

toggleBtn.MouseButton1Click:Connect(toggleLag)
modeValueBtn.MouseButton1Click:Connect(cycleMode)


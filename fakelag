-- Fake lag + Freeze engine
local lagCoroutine

local function startFakeLag()
    if lagCoroutine then return end
    
    lagCoroutine = task.spawn(function()
        local nextFreezeTime = tick() + freezeInterval
        
        while true do
            if not enabled then
                task.wait(0.2)
                continue
            end

            local char = player.Character
            if not char then 
                task.wait(0.5)
                continue 
            end

            local hrp = char:FindFirstChild("HumanoidRootPart")
            local humanoid = char:FindFirstChild("Humanoid")
            if not hrp or not humanoid then 
                task.wait(0.5)
                continue 
            end

            local originalCFrame = hrp.CFrame

            -- Main Lag Modes
            if lagMode == "Rubberband" or lagMode == "Burst" then
                local jitterFactor = 1.15 + math.random() * 0.55
                local offsetX = (math.random(-teleportStuds * 100, teleportStuds * 100) / 100) * jitterFactor
                local offsetZ = (math.random(-teleportStuds * 100, teleportStuds * 100) / 100) * jitterFactor
                hrp.CFrame = originalCFrame + Vector3.new(offsetX, 0, offsetZ)

                local currentJitter = teleportJitter * (0.75 + math.random() * 1.05)
                if useRandomJitter then
                    currentJitter = currentJitter * (0.85 + math.random() * 0.65)
                end
                task.wait(currentJitter)

                hrp.CFrame = originalCFrame

                if fakeRotation then
                    local rotY = math.rad((math.random() * 2 - 1) * rotationDegrees)
                    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, rotY, 0)
                end

                if lagMode == "Burst" or burstMode then
                    for i = 1, burstCount - 1 do
                        task.wait(currentJitter * 0.28)
                        local bJitter = jitterFactor * 0.65
                        local bOffsetX = (math.random(-teleportStuds * 50, teleportStuds * 50) / 100) * bJitter
                        local bOffsetZ = (math.random(-teleportStuds * 50, teleportStuds * 50) / 100) * bJitter
                        hrp.CFrame = originalCFrame + Vector3.new(bOffsetX, 0, bOffsetZ)
                        task.wait(currentJitter * 0.18)
                        hrp.CFrame = originalCFrame
                    end
                end

            elseif lagMode == "VelocityFreeze" then
                if fakeVelocity then
                    hrp.AssemblyLinearVelocity = Vector3.new(
                        math.random(-velocityAmount * 1.4, velocityAmount * 1.4),
                        math.random(-5, 15),
                        math.random(-velocityAmount * 1.4, velocityAmount * 1.4)
                    )
                end
                task.wait(teleportJitter * (1.3 + math.random() * 1.1))
                if hrp.AssemblyLinearVelocity then
                    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                end
            end

            -- Independent Freeze Feature
            if freezeEnabled and tick() >= nextFreezeTime then
                local origWalkSpeed = humanoid.WalkSpeed
                local origJumpPower = humanoid.JumpPower
                
                humanoid.WalkSpeed = 0
                humanoid.JumpPower = 0
                hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                
                task.wait(freezeDuration)
                
                humanoid.WalkSpeed = origWalkSpeed
                humanoid.JumpPower = origJumpPower
                
                nextFreezeTime = tick() + freezeInterval
            end

            local baseWait = (1.55 / math.clamp(lagStrength, 1, 10)) * (0.85 + math.random() * 0.5)
            task.wait(baseWait)
        end
    end)
end

local function stopFakeLag()
    enabled = false
    if lagCoroutine then
        task.cancel(lagCoroutine)
        lagCoroutine = nil
    end
end


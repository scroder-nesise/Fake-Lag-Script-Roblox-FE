-- ===== LAG ENGINE =====

local function stopFakeLag()
    -- NOTE: Does NOT touch `enabled`. Caller is responsible for that.
    if lagThread then
        task.cancel(lagThread)
        lagThread = nil
    end
    -- Safety: always unanchor the root if Precise mode left it anchored
    local char = player.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.Anchored = false end
    end
end

local function startFakeLag()
    stopFakeLag() -- Ensure clean start

    lagThread = task.spawn(function()
        local nextFreezeTime = tick() + freezeInterval

        while true do
            if not enabled then
                task.wait(0.2)
                continue
            end

            local char = player.Character
            if not char then task.wait(0.5); continue end

            local hrp      = char:FindFirstChild("HumanoidRootPart")
            local humanoid = char:FindFirstChild("Humanoid")
            if not hrp or not humanoid then task.wait(0.5); continue end

            -- ── Freeze Feature (ticks independently of lag mode) ──
            if freezeEnabled and tick() >= nextFreezeTime then
                local origSpeed = humanoid.WalkSpeed
                local origJump  = humanoid.JumpPower
                humanoid.WalkSpeed = 0
                humanoid.JumpPower = 0
                hrp.AssemblyLinearVelocity = Vector3.zero
                setStatus("Frozen  (" .. freezeDuration .. "s)", C.Freeze)
                task.wait(freezeDuration)
                if humanoid and humanoid.Parent then
                    humanoid.WalkSpeed = origSpeed
                    humanoid.JumpPower = origJump
                end
                nextFreezeTime = tick() + freezeInterval
                setStatus("ACTIVE - " .. lagMode, C.Green)
                task.wait(0.05)
                continue
            end

            local originalCFrame = hrp.CFrame

            -- ── [1] Precise — anchor/unanchor cycle (clean position-freeze desync) ──
            if lagMode == "Precise" then
                local internalSpeed = lagStrength + 5
                local freezeTime    = math.clamp(0.8 / internalSpeed, 0.05, 0.8)
                local unfreezeTime  = math.clamp(0.2 / internalSpeed, 0.05, 0.5)
                hrp.Anchored = true
                task.wait(freezeTime)
                hrp.Anchored = false
                task.wait(unfreezeTime)
                -- self-timed: skip baseWait at bottom
                continue

            -- ── [2] Rubberband / [3] Burst ──
            elseif lagMode == "Rubberband" or lagMode == "Burst" then
                local jitter = 1.15 + math.random() * 0.55
                local ox = (math.random(-teleportStuds*100, teleportStuds*100) / 100) * jitter
                local oz = (math.random(-teleportStuds*100, teleportStuds*100) / 100) * jitter
                hrp.CFrame = originalCFrame + Vector3.new(ox, 0, oz)

                local waitTime = teleportJitter * (0.75 + math.random() * 1.05)
                if useRandomJitter then
                    waitTime = waitTime * (0.85 + math.random() * 0.65)
                end
                task.wait(waitTime)
                hrp.CFrame = originalCFrame

                if fakeRotation then
                    local rotY = math.rad((math.random()*2 - 1) * rotationDegrees)
                    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, rotY, 0)
                end

                if lagMode == "Burst" or burstMode then
                    for _ = 1, burstCount - 1 do
                        task.wait(waitTime * 0.28)
                        local bj = jitter * 0.65
                        local bx = (math.random(-teleportStuds*50, teleportStuds*50) / 100) * bj
                        local bz = (math.random(-teleportStuds*50, teleportStuds*50) / 100) * bj
                        hrp.CFrame = originalCFrame + Vector3.new(bx, 0, bz)
                        task.wait(waitTime * 0.18)
                        hrp.CFrame = originalCFrame
                    end
                end

            -- ── [4] VelocityFreeze ──
            elseif lagMode == "VelocityFreeze" then
                if fakeVelocity then
                    hrp.AssemblyLinearVelocity = Vector3.new(
                        math.random(-velocityAmount, velocityAmount),
                        math.random(-5, 15),
                        math.random(-velocityAmount, velocityAmount)
                    )
                end
                task.wait(teleportJitter * (1.3 + math.random() * 1.1))
                hrp.AssemblyLinearVelocity = Vector3.zero

            -- ── [5] Ghost — simulates packet loss / position desync ──
            elseif lagMode == "Ghost" then
                hrp.CFrame = originalCFrame + Vector3.new(0, 800, 0)
                task.wait(0.04 + math.random() * 0.09)
                hrp.CFrame = originalCFrame
                if fakeVelocity then
                    hrp.AssemblyLinearVelocity = Vector3.new(
                        math.random(-velocityAmount, velocityAmount) * 0.4,
                        0,
                        math.random(-velocityAmount, velocityAmount) * 0.4
                    )
                    task.wait(0.07)
                    hrp.AssemblyLinearVelocity = Vector3.zero
                end
            end

            local baseWait = (1.55 / math.clamp(lagStrength, 1, 10)) * (0.85 + math.random() * 0.5)
            task.wait(baseWait)
        end
    end)
end

